# Copy this file to .env before starting middleware.

UID=0
GID=0
TZ=Asia/Shanghai
MIDDLEWARE_HOME=.

MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=multi-agent-demo
MYSQL_USER=multi_agent_demo
MYSQL_PASSWORD=change-me-db-password

LANG=C.UTF-8

# Generate a new Base64 string longer than 32 chars for production use.
NACOS_AUTH_TOKEN=replace-with-base64-secret-longer-than-32-chars
NACOS_AUTH_IDENTITY_KEY=serverIdentity
NACOS_AUTH_IDENTITY_VALUE=replace-with-nacos-identity-value
MODE=standalone

JVM_XMS=512m
JVM_XMX=512m
JVM_XMN=256m

REDIS_PASSWORD=change-me-redis-password
REDIS_DATABASE=0
REDIS_TIMEOUT=3000
REDIS_MAX_CONNECTIONS=100
REDIS_POOL_MAX_ACTIVE=8
REDIS_POOL_MAX_IDLE=8
REDIS_POOL_MIN_IDLE=0
REDIS_POOL_MAX_WAIT=3000
